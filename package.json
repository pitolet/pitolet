{
  "name": "pitolet-workspace",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Design web interfaces with real DOM and CSS, work alongside a coding agent, and export React or HTML.",
  "bin": {
    "pitolet": "./bin/pitolet.js"
  },
  "scripts": {
    "dev": "concurrently -n server,editor -c blue,cyan \"pnpm --filter ./packages/server dev\" \"pnpm --filter @pitolet/editor dev\"",
    "build": "pnpm build:site && pnpm --filter @pitolet/editor build && pnpm --filter ./packages/server build",
    "build:site": "node site/build.mjs",
    "start": "node bin/pitolet.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings 0",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "format": "prettier --write \"packages/**/*.{ts,tsx,css,mjs,json,md}\" \"apps/**/*.{ts,tsx,css,mjs,json,md}\" \"site/**/*.{ts,mjs,md}\" \"scripts/**/*.{mjs,js,ts}\" \"deploy/**/*.{yml,yaml,json,md,html}\" \".github/workflows/*.yml\" \"*.{json,js,mjs,ts,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,css,mjs,json,md}\" \"apps/**/*.{ts,tsx,css,mjs,json,md}\" \"site/**/*.{ts,mjs,md}\" \"scripts/**/*.{mjs,js,ts}\" \"deploy/**/*.{yml,yaml,json,md,html}\" \".github/workflows/*.yml\" \"*.{json,js,mjs,ts,md}\"",
    "check:site": "node scripts/check-site.mjs",
    "qa:site": "node packages/server/scripts/site-qa.mjs",
    "qa:editor": "node packages/server/scripts/editor-e2e.mjs",
    "check:package": "node scripts/check-package.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm audit:prod && pnpm build && pnpm typecheck && pnpm test && pnpm check:site && pnpm qa:site && pnpm qa:editor && pnpm check:package"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0"
}
