{
  "name": "@pitolet/cloud",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Pitolet Cloud, the commercial hosted service. Source is visible, but not open source (see LICENSE).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:dashboard": "vite --config dashboard/vite.config.ts",
    "build": "pnpm run build:server && pnpm run build:dashboard",
    "build:server": "tsup",
    "build:dashboard": "vite build --config dashboard/vite.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p dashboard/tsconfig.json"
  },
  "dependencies": {
    "@pitolet/schema": "workspace:*",
    "@pitolet/ui": "workspace:*",
    "better-auth": "^1.6.23",
    "immer": "^10.2.0",
    "lucide-react": "^0.525.0",
    "nanoid": "^5.1.16",
    "pg": "^8.16.0",
    "pitolet": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
